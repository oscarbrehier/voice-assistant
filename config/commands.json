{
  "static_commands": [
    {
      "action": "PlayMusic",
      "description": "Play/Pause the currently playing media",
      "triggers": ["play music", "play song", "start song", "pause music"]
    },
    {
      "action": "GetTime",
      "description": "Get the local time",
      "triggers": ["what time is it", "give me the time"]
    }
  ],
  "dynamic_commands": [
    {
      "action": "OpenApp",
      "description": "Open a specific app",
      "patterns": ["open {}", "launch {}", "start {}"],
      "regex": "^(?:open|launch|start)\\s+(\\w+)$",
      "arg_types": ["app"],
      "generate_message": false
    },
    {
      "action": "WebSearch",
      "description": "Search a topic on the internet",
      "patterns": ["search {}"],
      "regex": "^search\\s+(.+)$",
      "arg_types": ["query"],
      "generate_message": true
    }
  ]
}
